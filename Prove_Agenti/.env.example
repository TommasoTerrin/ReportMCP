# ──────────────────────────────────────────────────
# Copia questo file in ".env" e personalizza i valori
# ──────────────────────────────────────────────────

# URL pubblico della tua app (deve corrispondere al callback_url)
# In locale: http://localhost:3000
# In produzione: https://tuodominio.com
APP_BASE_URL=http://localhost:3000

# Nome dell'app mostrato su OpenRouter
APP_NAME=FastAPI OpenRouter Demo

# Modello di default usato nel chat (usa modelli :free per test gratuiti)
TEST_MODEL=meta-llama/llama-3.1-8b-instruct:free
